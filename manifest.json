{
  "manifest_version": 3,
  "name": "Twitch Ad Blocker (全チャンネル対応)",
  "version": "1.0.0",
  "description": "Twitch の動画広告（ミッドロール含む）と表示広告・トラッキングをブロックします。全チャンネル対応。",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "declarativeNetRequest",
    "storage",
    "scripting",
    "tabs"
  ],
  "host_permissions": [
    "*://*.twitch.tv/*",
    "*://*.ttvnw.net/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "twitch_ads_ruleset",
        "enabled": true,
        "path": "rules.json"
      }
    ]
  },
  "content_scripts": [
    {
      "matches": ["*://*.twitch.tv/*"],
      "js": ["content.js"],
      "run_at": "document_start",
      "all_frames": true
    },
    {
      "matches": ["*://*.twitch.tv/*"],
      "js": ["worker-hook.js"],
      "run_at": "document_start",
      "all_frames": true,
      "world": "MAIN"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["worker-hook.js"],
      "matches": ["*://*.twitch.tv/*"]
    }
  ]
}
